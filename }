* {
    padding: 0;
    margin: 0;
    box-sizing: border-box;
}

body {
    background: #1f1b1b;
    font-family: monospace;
    color: white;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

.header__title {
    margin-top: 2%;
    font-size: 2rem;
    text-align: center;
}

.body__content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 2rem;
  gap: 0.5rem;
}

.calculator {
  display: flex;
  justify-content: center;
  margin-top: 2rem;
}

.calculator__controls {
  display: flex;
  flex-direction: column;
  min-height: 40%;
  padding: 1rem;
  border: 2px solid #ffffff;
  border-radius: 12px;
}


/* Calculator: Keypad section */

.calculator__keypad {
  display: flex;
  flex-direction: column;
  align-items: center;
}

button {
  width: 1rem;
}
